        <script><![CDATA[(function executeRule(current, previous) {

    if (current.delivery_type == 'home_delivery') {

        var gr = new GlideRecord('x_2094840_satya_0_serviceable_pincode');

        gr.addQuery('pincode', current.pincode);
        gr.query();

        if (gr.next()) {

            if (!gr.delivery_available) {

                gs.addErrorMessage('Home Delivery is not available for this pincode. Please choose Self Pickup.');
                current.setAbortAction(true);

            }

        } else {

            gs.addErrorMessage('Entered pincode is not serviceable. Please choose Self Pickup.');
            current.setAbortAction(true);

        }
    }

})(current, previous);]]></script>
